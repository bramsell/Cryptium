# Unreal Engine 5 .gitignore
# https://github.com/github/gitignore/blob/master/UnrealEngine.gitignore

# Binaries, Plugins and intermediate files generated by the engine
/Binaries/
/Intermediate/
/Plugins/Marketplace/*/Binaries/
/Plugins/Marketplace/*/Intermediate/
/Source/ThirdParty/*/Binaries/
/Source/ThirdParty/*/Intermediate/

# Cache files for the editor to use
DerivedDataCache/

# Saved game files and editor save data
/Saved/

# Temporary files
*.tmp
*.temp

# Logs
Logs/
*.log

# Visual Studio files
.vs/
.sln
*.sln.DotSettings
*.VC.db
*.VC.db-shm
*.VC.db-wal

# Build results
/Intermediate/
*.dll
*.exe
*.lib
*.a
*.o
*.obj
*.lib
*.exp
*.ilk
*.pdb
*.idb

# IDE files
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# Generated files
*.generated.h
*.gen.cpp

# User-specific files
*.VC.db
*.VC.db-shm
*.VC.db-wal

# Rider files
.idea/
*.sln.iml
*.rider

# Generated project files
*.xcworkspace/

# Misc
.vscode/
.editorconfig

# Source Control/Version Control
.git/
.svn/
.hg/

# IDE temporary files
*.swp
*.swo
*~

# Mac OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
